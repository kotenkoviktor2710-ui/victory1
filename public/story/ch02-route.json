    "scene_ch02_observe": {
      "id": "scene_ch02_observe",
      "title": "Городская улица — 09:15",
      "backgroundKey": "BG_06",
      "characterLayers": [],
      "lines": [
        {
          "kind": "narration",
          "text": "Артём садится на остановке и наблюдает. Один и тот же мужчина роняет стакан кофе. Женщина в красном шарфе смотрит на часы. Светофор переключается на секунду раньше.",
          "thought": false
        },
        {
          "kind": "dialogue",
          "text": "Город репетирует.",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "narration",
          "text": "На рекламном экране появляется текст:\n\nНе отклоняйтесь от маршрута.",
          "thought": false
        },
        {
          "kind": "dialogue",
          "text": "А если отклонюсь?",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "narration",
          "text": "Экран меняется:\n\nПоследствия будут исправлены.",
          "thought": false
        }
      ],
      "choices": [
        {
          "id": "ch02g_record",
          "text": "Записать повторяющиеся события",
          "nextSceneId": "scene_ch02_observe_record"
        },
        {
          "id": "ch02g_help",
          "text": "Нарушить повтор и помочь мужчине с кофе",
          "nextSceneId": "scene_ch02_observe_help"
        },
        {
          "id": "ch02g_follow",
          "text": "Следовать подсказке экрана",
          "nextSceneId": "scene_ch02_observe_follow"
        },
        {
          "id": "ch02g_call_nika",
          "text": "Позвонить Нике",
          "nextSceneId": "scene_ch02_observe_nika"
        }
      ],
      "actBreak": null,
      "autoNextSceneId": null
    },
