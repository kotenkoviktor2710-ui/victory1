{
  "scenes": {
    "scene_ch02_cafe": {
      "id": "scene_ch02_cafe",
      "title": "Кафе «Минута» — 09:20",
      "backgroundKey": "BG_03",
      "characterLayers": [],
      "lines": [
        {
          "kind": "narration",
          "text": "Тёплое кафе. За окном городская суета. У окна сидит Ника с камерой и ноутбуком.",
          "thought": false
        },
        {
          "kind": "dialogue",
          "text": "Ты Артём?",
          "thought": false,
          "speaker": "char_nika"
        },
        {
          "kind": "dialogue",
          "text": "Зависит от того, кто спрашивает.",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "Человек, который видел твоё фото в чужом телефоне.",
          "thought": false,
          "speaker": "char_nika"
        },
        {
          "kind": "narration",
          "text": "Она показывает снимок. На нём Артём стоит на перекрёстке вечером. Время на фото — 19:43.",
          "thought": false
        },
        {
          "kind": "dialogue",
          "text": "Это невозможно. Сейчас утро.",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "Вот поэтому я и позвала тебя.",
          "thought": false,
          "speaker": "char_nika"
        },
        {
          "kind": "dialogue",
          "text": "Ты меня не звала. Телефон отправил меня сюда.",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "Тогда у нас проблема больше, чем я думала.",
          "thought": false,
          "speaker": "char_nika"
        }
      ],
      "choices": [
        {
          "id": "ch02a_tell_all",
          "text": "Рассказать Нике всё",
          "nextSceneId": "scene_ch02_cafe_tell"
        },
        {
          "id": "ch02a_hide_truth",
          "text": "Скрыть часть правды",
          "nextSceneId": "scene_ch02_cafe_hide"
        },
        {
          "id": "ch02a_take_photo",
          "text": "Забрать фото и уйти",
          "nextSceneId": "scene_ch02_cafe_take"
        },
        {
          "id": "ch02a_cameras",
          "text": "Попросить Нику проверить камеры",
          "nextSceneId": "scene_ch02_cafe_cameras"
        }
      ],
      "actBreak": null,
      "autoNextSceneId": null
    },
    "scene_ch02_cafe_tell": {
      "id": "scene_ch02_cafe_tell",
      "title": "",
