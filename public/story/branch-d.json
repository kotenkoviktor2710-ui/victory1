      "id": "scene_d1_route",
      "title": "Ветка D — Идеальный маршрут — 09:00",
      "backgroundKey": "BG_06",
      "characterLayers": [],
      "lines": [
        {
          "kind": "narration",
          "text": "Телефон показывает точный маршрут.",
          "thought": false
        },
        {
          "kind": "dialogue",
          "text": "Следуйте инструкциям. Отклонение не требуется.",
          "thought": false,
          "speaker": "char_sync"
        },
        {
          "kind": "narration",
          "text": "Мужчина не роняет кофе. Автобус приходит вовремя. Люди не сталкиваются. Всё идеально.",
          "thought": false
        },
        {
          "kind": "dialogue",
          "text": "Это должно радовать.",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "Радость не является обязательной для стабильности.",
          "thought": false,
          "speaker": "char_sync"
        },
        {
          "kind": "dialogue",
          "text": "Вот это как раз и пугает.",
          "thought": false,
          "speaker": "char_artem"
        }
      ],
      "choices": [
        {
          "id": "d1_follow",
