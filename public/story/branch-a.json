    "scene_a_final": {
      "id": "scene_a_final",
      "title": "Финал A — Один спасённый день",
      "backgroundKey": "BG_08",
      "characterLayers": [],
      "lines": [
        {
          "kind": "narration",
          "text": "Артём спасает Аню на перекрёстке.",
          "thought": false
        },
        {
          "kind": "dialogue",
          "text": "Ты правда уже видел это?",
          "thought": false,
          "speaker": "char_anya"
        },
        {
          "kind": "dialogue",
          "text": "Да.",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "И каждый раз пытался помочь?",
          "thought": false,
          "speaker": "char_anya"
        },
        {
          "kind": "dialogue",
          "text": "Не каждый. Но теперь буду.",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "narration",
          "text": "Аварии нет. Телефон вибрирует:\n\nЦель защищена.\nСистемная ошибка сохраняется.",
          "thought": false
        },
        {
          "kind": "dialogue",
          "text": "Мы спасли её.",
          "thought": false,
          "speaker": "char_lera"
        },
        {
          "kind": "dialogue",
          "text": "Но не день.",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "Повтор запущен.",
          "thought": false,
          "speaker": "char_sync"
        },
        {
          "kind": "narration",
          "text": "Спасти одного человека оказалось недостаточно. Где-то в логах снова загорелся тот же таймер.",
          "thought": false
        }
      ],
