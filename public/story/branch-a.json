    "scene_a2_sisters": {
      "id": "scene_a2_sisters",
      "title": "Лера и Аня — 17:20",
      "backgroundKey": "BG_11",
      "characterLayers": [],
      "lines": [
        {
          "kind": "narration",
          "text": "Крыша здания.",
          "thought": false
        },
        {
          "kind": "dialogue",
          "text": "Ты всегда говоришь так, будто всё можно посчитать.",
          "thought": false,
          "speaker": "char_anya"
        },
        {
          "kind": "dialogue",
          "text": "Я не говорила, что можно посчитать всё.",
          "thought": false,
          "speaker": "char_lera"
        },
        {
          "kind": "dialogue",
          "text": "Но ты пыталась.",
          "thought": false,
          "speaker": "char_anya"
        },
        {
          "kind": "dialogue",
          "text": "Я пыталась сделать город безопаснее.",
          "thought": false,
          "speaker": "char_lera"
        },
        {
          "kind": "dialogue",
          "text": "А получился день, из которого никто не может выйти?",
          "thought": false,
          "speaker": "char_anya"
        },
        {
          "kind": "dialogue",
          "text": "Система зациклила день из-за аварии?",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "Из-за вероятности аварии. Она не знает, что именно случится. Она видит только, что к 19:43 все варианты становятся плохими.",
          "thought": false,
          "speaker": "char_lera"
        }
      ],
      "choices": [
        {
          "id": "a2_leave",
          "text": "Увести Аню из центра",
          "nextSceneId": "scene_a2_leave"
        },
        {
          "id": "a2_stay",
          "text": "Остаться на перекрёстке и изменить момент",
          "nextSceneId": "scene_a_final"
        },
        {
          "id": "a2_orlova",
          "text": "Передать данные Орловой",
          "nextSceneId": "scene_a_orlova"
        },
        {
          "id": "a2_nika",
          "text": "Подключить Нику",
          "nextSceneId": "scene_a_nika"
        }
      ],
      "actBreak": null,
      "autoNextSceneId": null
    },
