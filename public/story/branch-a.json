  "scenes": {
    "scene_a1_search": {
      "id": "scene_a1_search",
      "title": "Ветка A — Поиск Ани — 12:15",
      "backgroundKey": "BG_06",
      "characterLayers": [],
      "lines": [
        {
          "kind": "narration",
          "text": "Бублик тянет Артёма к остановке. Там стоит Аня и спорит по телефону.",
          "thought": false
        },
        {
          "kind": "dialogue",
          "text": "Лера, я не собираюсь снова ждать. Ты обещала, что сегодня всё закончится.",
          "thought": false,
          "speaker": "char_anya"
        },
        {
          "kind": "dialogue",
          "text": "Извини. Ты Аня?",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "Мы знакомы?",
          "thought": false,
          "speaker": "char_anya"
        },
        {
          "kind": "dialogue",
          "text": "Сложный вопрос. Я видел тебя у перекрёстка.",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "Меня многие видели у перекрёстка. Это не делает нас друзьями.",
          "thought": false,
          "speaker": "char_anya"
        }
      ],
      "choices": [
        {
          "id": "a1_loop",
          "text": "Сказать, что день повторяется",
          "nextSceneId": "scene_a1_loop"
        },
        {
          "id": "a1_danger",
          "text": "Сказать, что ей грозит опасность",
          "nextSceneId": "scene_a1_danger"
        },
        {
          "id": "a1_avoid",
          "text": "Попросить не идти на перекрёсток",
          "nextSceneId": "scene_a1_avoid"
        },
        {
          "id": "a1_lera",
          "text": "Позвать Леру",
          "nextSceneId": "scene_a2_sisters"
        }
      ],
      "actBreak": null,
      "autoNextSceneId": null
    },
    "scene_a1_loop": {
