    "scene_ch04_truth_orlova": {
      "id": "scene_ch04_truth_orlova",
      "title": "",
      "backgroundKey": "BG_01",
      "characterLayers": [],
      "lines": [
        {
          "kind": "dialogue",
          "text": "Инспектор, у меня новые улики. И память о вчерашнем дне.",
          "thought": false,
          "speaker": "char_artem"
        }
      ],
      "choices": [],
