    "scene_ch04_sync_office": {
      "id": "scene_ch04_sync_office",
      "title": "Офис «Синхрон» — поиск предметов 3",
      "backgroundKey": "BG_10",
      "characterLayers": [],
      "lines": [
        {
          "kind": "narration",
          "text": "Поиск предметов — Офис «Синхрон». Найдено:\n1. Схема перекрёстка.\n2. Лог ошибок системы.\n3. Пропуск в серверную.\n4. Запись совещания.\n5. Черновик отчёта о петле.\n6. Карта маршрутов курьеров.\n7. Список «устойчивых переменных».\n8. Модуль диагностики.",
          "thought": false
        },
        {
          "kind": "dialogue",
          "text": "Они знали, что день будет повторяться.",
          "thought": false,
          "speaker": "char_artem"
        }
      ],
      "choices": [],
      "actBreak": null,
      "autoNextSceneId": "scene_ch04_hub"
    },
