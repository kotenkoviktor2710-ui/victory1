    "scene_ch04_lera_meet": {
      "id": "scene_ch04_lera_meet",
      "title": "Первая встреча с Лерой — 11:40",
      "backgroundKey": "BG_09",
      "characterLayers": [],
      "lines": [
        {
          "kind": "narration",
          "text": "Кафе или лобби компании. У Артёма в кармане бейдж «Синхрон».",
          "thought": false
        },
        {
          "kind": "dialogue",
          "text": "Ты не должен был помнить.",
          "thought": false,
          "speaker": "char_lera"
        },
        {
          "kind": "dialogue",
          "text": "Обычно люди начинают с «здравствуйте».",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "Если ты помнишь прошлый цикл, значит, система отметила тебя как устойчивую переменную.",
          "thought": false,
          "speaker": "char_lera"
        },
        {
          "kind": "dialogue",
          "text": "Звучит почти как повышение.",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "Нет. Это значит, что она будет использовать тебя снова и снова, пока не получит нужный результат.",
          "thought": false,
          "speaker": "char_lera"
        },
        {
          "kind": "dialogue",
          "text": "Кто она?",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "«Синхрон».",
          "thought": false,
          "speaker": "char_lera"
        },
        {
          "kind": "narration",
          "text": "Лера показывает карту города. На ней маршруты людей, точка 19:43 и имя Артёма.",
          "thought": false
        },
        {
          "kind": "dialogue",
          "text": "Почему я?",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "Потому что твоя посылка каждый раз оказывается в центре события.",
          "thought": false,
          "speaker": "char_lera"
        }
      ],
      "choices": [
        {
          "id": "ch04_lera_trust",
          "text": "Довериться Лере",
          "nextSceneId": "scene_ch04_lera_trust"
        },
        {
          "id": "ch04_lera_questions",
          "text": "Задать жёсткие вопросы",
          "nextSceneId": "scene_ch04_lera_questions"
        },
        {
          "id": "ch04_lera_blame",
          "text": "Обвинить её",
          "nextSceneId": "scene_ch04_lera_blame"
        },
        {
          "id": "ch04_lera_pretend",
          "text": "Сделать вид, что веришь, но скрыть посылку",
          "nextSceneId": "scene_ch04_lera_pretend"
        }
      ],
      "actBreak": null,
      "autoNextSceneId": null
    },
    "scene_ch04_lera_trust": {
      "id": "scene_ch04_lera_trust",
