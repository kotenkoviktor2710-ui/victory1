{
  "scenes": {
    "scene_ch04_apartment": {
      "id": "scene_ch04_apartment",
      "title": "Квартира — второе утро, 08:12",
      "backgroundKey": "BG_01",
      "characterLayers": [],
      "lines": [
        {
          "kind": "narration",
          "text": "Квартира утром, но с мелкими отличиями. На столе остаётся одна улика из прошлого цикла.",
          "thought": false
        },
        {
          "kind": "narration",
          "text": "Спасал девушку — фото с новой надписью. Доставлял посылку — повреждённая пломба. Снимал видео — испорченный файл. Слушался «Синхрон» — сообщение «Вы почти помогли». Создал хаос — чёрный экран телефона.",
          "thought": false
        },
        {
          "kind": "narration",
          "text": "Звонит Макс.",
          "thought": false
        },
        {
          "kind": "dialogue",
          "text": "Ты живой?",
          "thought": false,
          "speaker": "char_max"
        },
        {
          "kind": "dialogue",
          "text": "Скажи что-нибудь, чего ты не говорил вчера.",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "Я вчера тебе звонил?",
          "thought": false,
          "speaker": "char_max"
        },
        {
          "kind": "dialogue",
          "text": "Вот теперь разговор становится интересным.",
          "thought": false,
          "speaker": "char_artem"
        }
      ],
      "choices": [
        {
          "id": "ch04_truth_max",
          "text": "Рассказать правду Максу",
          "nextSceneId": "scene_ch04_truth_max"
        },
        {
          "id": "ch04_truth_nika",
          "text": "Рассказать правду Нике",
          "nextSceneId": "scene_ch04_truth_nika"
        },
        {
          "id": "ch04_truth_orlova",
          "text": "Рассказать правду Орловой",
          "nextSceneId": "scene_ch04_truth_orlova"
        },
        {
          "id": "ch04_truth_lera",
          "text": "Рассказать правду Лере",
          "nextSceneId": "scene_ch04_truth_lera"
        },
        {
          "id": "ch04_truth_nobody",
          "text": "Никому не рассказывать",
          "nextSceneId": "scene_ch04_truth_nobody"
        }
      ],
      "actBreak": null,
      "autoNextSceneId": null
    },
    "scene_ch04_truth_max": {
      "id": "scene_ch04_truth_max",
      "title": "",
      "backgroundKey": "BG_01",
      "characterLayers": [],
      "lines": [
        {
          "kind": "dialogue",
          "text": "День повторяется. Я помню вчерашний вечер. И 19:43.",
          "thought": false,
          "speaker": "char_artem"
        },
        {
          "kind": "dialogue",
          "text": "Тогда я не зря приехал.",
          "thought": false,
          "speaker": "char_max"
        }
      ],
      "choices": [],
      "actBreak": null,
      "autoNextSceneId": "scene_ch04_lera_meet"
    },
    "scene_ch04_truth_nika": {
      "id": "scene_ch04_truth_nika",
      "title": "",
      "backgroundKey": "BG_01",
      "characterLayers": [],
      "lines": [
        {
          "kind": "dialogue",
          "text": "Ника, это не монтаж. День зациклен.",
          "thought": false,
          "speaker": "char_artem"
        }
      ],
      "choices": [],
      "actBreak": null,
      "autoNextSceneId": "scene_ch04_lera_meet"
